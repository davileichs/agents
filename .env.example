# ─── Core / API Gateway ───────────────────────────────────────────────────────
API_KEY=
DATABASE_URL=

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Provider: openai | anthropic | google | ollama
LLM=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
# Optional: override the base URL (e.g. for Ollama or a custom proxy)
LLM_API_BASE=

# ─── Weather Agent ─────────────────────────────────────────────────────────────
# https://openweathermap.org/api
OPEN_WEATHER_KEY=

# ─── Travel Agent ─────────────────────────────────────────────────────────────
# SerpApi – used by flight_search
# https://serpapi.com
SERPAPI_API_KEY=

# currency_converter uses the free ECB daily XML feed – no API key required.
# https://www.ecb.europa.eu/stats/policy_and_exchange_rates/euro_reference_exchange_rates/

# ─── Necesse Agent (GPortal FTP) ──────────────────────────────────────────────
GPORTAL_IP=
GPORTAL_PORT=21
GPORTAL_USER=
GPORTAL_PASSWORD=
GPORTAL_FILE_PATH=
